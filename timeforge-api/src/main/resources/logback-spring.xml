<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="LOG_FILE" source="LOG_FILE_PATH" defaultValue="logs/timeforge-api.log"/>
    <springProperty scope="context" name="ROOT_LOG_LEVEL" source="LOG_ROOT_LEVEL" defaultValue="INFO"/>
    <springProperty scope="context" name="APP_LOG_LEVEL" source="LOG_APP_LEVEL" defaultValue="DEBUG"/>
    <springProperty scope="context" name="SECURITY_LOG_LEVEL" source="LOG_SECURITY_LEVEL" defaultValue="INFO"/>

    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%X{requestId:-sem-request-id}] [%thread] %logger{36} - %msg%n"/>
    <property name="LOG_ARCHIVE_PATTERN" value="${LOG_FILE}.%d{yyyy-MM-dd}.%i.gz"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_ARCHIVE_PATTERN}</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>14</maxHistory>
            <totalSizeCap>200MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <logger name="br.com.timeforge.timeforge_api" level="${APP_LOG_LEVEL}"/>
    <logger name="org.springframework.security" level="${SECURITY_LOG_LEVEL}"/>

    <root level="${ROOT_LOG_LEVEL}">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
